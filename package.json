{
  "name": "stream-9",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo workspace for a video streaming platform with a Next.js App Router frontend and Node.js backend.",
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "dev:web": "npm run dev --workspace @stream-9/web",
    "dev:api": "npm run dev --workspace @stream-9/api",
    "build": "npm run build --workspaces --if-present",
    "build:web": "npm run build --workspace @stream-9/web",
    "build:api": "npm run build --workspace @stream-9/api",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "tsc --build",
    "prisma:generate": "prisma generate --schema apps/api/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema apps/api/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "lucide-react": "1.17.0",
    "next": "16.2.9",
    "pg": "8.21.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sharp": "^0.34.5",
    "video.js": "8.23.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.0",
    "@types/node": "25.9.3",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.5.0",
    "postcss": "8.5.15",
    "prisma": "7.8.0",
    "tailwindcss": "4.3.0",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=11.0.0"
  }
}
