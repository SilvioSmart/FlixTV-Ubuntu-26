generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum VideoCategory {
  REAL_TIME
  DMAX
  NOVE
  FOOD_NETWORK
  HGTV
  MOTOR_TREND
  WARNER_TV
  DISCOVERY
  OTHER
}

model User {
  id             String         @id @default(cuid())
  name           String?
  email          String?        @unique
  emailVerified  DateTime?
  image          String?
  accounts       Account[]
  watchHistories WatchHistory[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model MenuItem {
  id        String     @id @default(cuid())
  label     String
  slug      String
  href      String?
  parentId  String?
  sortOrder Int        @default(0)
  isActive  Boolean    @default(true)
  location  String     @default("homepage")
  parent    MenuItem?  @relation("MenuTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  MenuItem[] @relation("MenuTree")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([location, parentId, slug])
  @@index([location, parentId, sortOrder])
  @@index([isActive])
  @@map("menu")
}

model HomepageSlide {
  id              String   @id @default(cuid())
  title           String
  subtitle        String?
  notes           String?  @db.Text
  imageUrl        String
  linkUrl         String?
  linkLabel       String?
  secondaryLinkLabel String?
  notesColor      String   @default("#ffffff")
  buttonTextColor String   @default("#000000")
  buttonBgColor   String   @default("#ffffff")
  imageEffectMs   Int      @default(6000)
  textEffectMs    Int      @default(1500)
  sortOrder       Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isActive, sortOrder])
  @@map("homepage")
}

model ModuleConfig {
  id         String   @id @default(cuid())
  slug       String   @unique
  title      String
  subtitle   String?
  buttonLabel String?
  buttonUrl   String?
  mediaQuery Json
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([isActive, sortOrder])
  @@map("moduli")
}

model MediaStorageConfig {
  id            String   @id @default("default")
  uploadPath    String
  convertedPath String
  thumbnailPath String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("media_config")
}

model VastConfig {
  id        String   @id @default("default")
  vastUrl   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("vast_config")
}

model MediaFieldOption {
  id        String   @id @default(cuid())
  fieldName String
  label     String
  value     String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([fieldName, value])
  @@index([fieldName, sortOrder])
  @@index([isActive])
  @@map("media_field_options")
}

model ProgramDetail {
  id           String   @id @default(cuid())
  programCode  String   @default("")
  seasonCode   String   @default("")
  categoria    String
  programma    String
  serie        String
  stagione     String
  numeroPuntate Int     @default(0)
  episodes      ProgramEpisode[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([categoria])
  @@index([programma])
  @@index([serie])
  @@index([programCode])
  @@index([seasonCode])
  @@map("programmi")
}

model ProgramEpisode {
  id                String        @id @default(cuid())
  episodeCode       String        @default("") @db.VarChar(6)
  seasonId          String
  seriesId          String
  episodeNumber     Int
  productionCode    String?
  title             String        @db.VarChar(150)
  shortPlot         String?       @db.VarChar(250)
  longPlot          String?       @db.Text
  thumbnailUrl      String?
  mezzanineFileUrl  String?
  trailerUrl        String?
  subtitles         Json          @default("[]")
  audioTracks       Json          @default("[]")
  duration          Int           @default(0)
  cuePoints         Json          @default("{}")
  maxResolution     String        @default("FHD")
  audioFormats      Json          @default("[]")
  publicationStatus String        @default("Draft")
  publishAt         DateTime?
  licensingEnd      DateTime?
  geoRestrictions   Json          @default("[]")
  accessLevel       String        @default("Free")
  season            ProgramDetail @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([seasonId, episodeNumber])
  @@index([seriesId])
  @@index([episodeCode])
  @@index([publicationStatus])
  @@map("program_episodes")
}

model LiveChannel {
  id        String            @id @default(cuid())
  name      String
  logoUrl   String
  streamUrl String
  isActive  Boolean           @default(true)
  schedules ProgramSchedule[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([isActive])
  @@index([name])
}

model ProgramSchedule {
  id          String      @id @default(cuid())
  channelId   String
  title       String
  description String?     @db.Text
  startTime   DateTime
  endTime     DateTime
  channel     LiveChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([channelId, startTime])
  @@index([startTime, endTime])
}

model VideoContent {
  id             String         @id @default(cuid())
  title          String
  description    String?        @db.Text
  thumbnailUrl   String
  videoUrl       String
  duration       Int
  category       VideoCategory
  releaseDate    DateTime
  watchHistories WatchHistory[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([category, releaseDate])
  @@index([releaseDate])
  @@index([title])
}

model WatchHistory {
  userId              String
  videoId             String
  currentPlaybackTime Int          @default(0)
  updatedAt           DateTime     @updatedAt
  createdAt           DateTime     @default(now())
  user                User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  video               VideoContent @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@id([userId, videoId])
  @@index([userId, updatedAt])
  @@index([videoId])
}
